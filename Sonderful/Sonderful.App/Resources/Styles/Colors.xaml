<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand — Indigo -->
    <Color x:Key="Brand">#4F46E5</Color>
    <Color x:Key="BrandDark">#3730A3</Color>
    <Color x:Key="BrandLight">#EEF2FF</Color>
    <Color x:Key="BrandMid">#6366F1</Color>

    <!-- Ink (text) -->
    <Color x:Key="Ink">#111827</Color>
    <Color x:Key="InkSecondary">#6B7280</Color>
    <Color x:Key="InkMuted">#9CA3AF</Color>

    <!-- Surfaces -->
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="PageBg">#F5F5FA</Color>
    <Color x:Key="InputBg">#F3F4F6</Color>
    <Color x:Key="InputBorder">#E5E7EB</Color>
    <Color x:Key="Divider">#F0F0F5</Color>

    <!-- Semantic -->
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="SuccessLight">#D1FAE5</Color>
    <Color x:Key="Warning">#F59E0B</Color>

    <!-- Legacy keys kept for Shell / system compatibility -->
    <Color x:Key="Primary">#4F46E5</Color>
    <Color x:Key="PrimaryDark">#818CF8</Color>
    <Color x:Key="PrimaryDarkText">#EEF2FF</Color>
    <Color x:Key="Secondary">#EEF2FF</Color>
    <Color x:Key="SecondaryDarkText">#4F46E5</Color>
    <Color x:Key="Tertiary">#3730A3</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#111827</Color>
    <Color x:Key="Magenta">#4F46E5</Color>
    <Color x:Key="MidnightBlue">#111827</Color>
    <Color x:Key="OffBlack">#1A1A2E</Color>

    <!-- Gray scale -->
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#374151</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#0F0F1A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrandBrush"       Color="{StaticResource Brand}"/>
    <SolidColorBrush x:Key="BrandLightBrush"  Color="{StaticResource BrandLight}"/>
    <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource Brand}"/>
    <SolidColorBrush x:Key="SecondaryBrush"   Color="{StaticResource BrandLight}"/>
    <SolidColorBrush x:Key="TertiaryBrush"    Color="{StaticResource BrandDark}"/>
    <SolidColorBrush x:Key="WhiteBrush"       Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"       Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorder}"/>
    <SolidColorBrush x:Key="Gray100Brush"     Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"     Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"     Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"     Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"     Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"     Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"     Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"     Color="{StaticResource Gray950}"/>

</ResourceDictionary>
