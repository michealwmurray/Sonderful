<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PageBg}" />
    </Style>

    <!-- Shell / Nav -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource Gray300}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource Gray400}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Brand}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Brand}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource Gray400}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="BarTextColor" Value="{StaticResource Ink}" />
        <Setter Property="IconColor" Value="{StaticResource Ink}" />
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Named label styles -->
    <Style x:Key="DisplayLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaExtraBold" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="LineHeight" Value="1.1" />
    </Style>

    <Style x:Key="HeadingLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaBold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="SubheadingLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource InkSecondary}" />
        <Setter Property="LineHeight" Value="1.5" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaMedium" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
    </Style>

    <!-- Button (primary — black pill) -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                            <Setter Property="BackgroundColor" Value="{StaticResource Gray200}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Brand (indigo) button variant -->
    <Style x:Key="BrandButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Brand}" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Ghost / outline button variant -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Danger button -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="BackgroundColor" Value="{StaticResource DangerLight}" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Entry -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="PlaceholderColor" Value="{StaticResource InkMuted}" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Editor -->
    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="PlaceholderColor" Value="{StaticResource InkMuted}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Picker -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="TitleColor" Value="{StaticResource InkMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                            <Setter Property="TitleColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- DatePicker -->
    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- TimePicker -->
    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- SearchBar -->
    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource InkMuted}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource InkSecondary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="FontFamily" Value="JakartaRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Border -->
    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource InputBorder}" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <!-- ActivityIndicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Brand}" />
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Brand}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Switch -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Brand}" />
        <Setter Property="ThumbColor" Value="{StaticResource White}" />
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Brand}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource Gray200}" />
        <Setter Property="ThumbColor" Value="{StaticResource Brand}" />
    </Style>

    <!-- ProgressBar -->
    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Brand}" />
    </Style>

    <!-- RefreshView -->
    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource Brand}" />
    </Style>

    <!-- IndicatorView -->
    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{StaticResource Gray200}" />
        <Setter Property="SelectedIndicatorColor" Value="{StaticResource Brand}" />
    </Style>

    <!-- ImageButton -->
    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- BoxView -->
    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource Divider}" />
    </Style>

    <!-- Shadow -->
    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="12" />
        <Setter Property="Opacity" Value="0.08" />
        <Setter Property="Brush" Value="{StaticResource BlackBrush}" />
        <Setter Property="Offset" Value="0,4" />
    </Style>

    <!-- TabbedPage -->
    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="BarTextColor" Value="{StaticResource Brand}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource Gray400}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource Brand}" />
    </Style>

    <!-- Shared card style (Border-based) -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource BlackBrush}" Offset="0,2" Radius="10" Opacity="0.07" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Input field wrapper (styled Border around Entry/Picker etc.) -->
    <Style x:Key="InputFieldBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="Stroke" Value="{StaticResource InputBorder}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="14" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="14,0" />
    </Style>

    <!-- Category chip style -->
    <Style x:Key="ChipBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="14,7" />
    </Style>

</ResourceDictionary>
