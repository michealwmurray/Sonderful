<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sonderful.App.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Sonderful.App.ViewModels"
    x:DataType="vm:ProfileViewModel"
    Title=""
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- fixed height so the avatar doesn't get clipped on Windows -->
            <Grid HeightRequest="230">
                <!-- Colored bar -->
                <Border
                    BackgroundColor="{StaticResource Brand}"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    HeightRequest="180"
                    VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,36,36" />
                    </Border.StrokeShape>
                </Border>

                <!-- Avatar -->
                <Grid HorizontalOptions="Center" VerticalOptions="End">
                        <!-- Initials fallback -->
                        <Border
                            HeightRequest="100"
                            WidthRequest="100"
                            BackgroundColor="{StaticResource BrandDark}"
                            Stroke="{StaticResource Surface}"
                            StrokeThickness="4"
                            HorizontalOptions="Center"
                            IsVisible="{Binding HasNoPhoto}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50" />
                            </Border.StrokeShape>
                            <Label
                                Text="{Binding Initials}"
                                FontFamily="JakartaExtraBold"
                                FontSize="38"
                                TextColor="White"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <!-- Photo -->
                        <Border
                            HeightRequest="100"
                            WidthRequest="100"
                            Stroke="{StaticResource Surface}"
                            StrokeThickness="4"
                            HorizontalOptions="Center"
                            IsVisible="{Binding HasPhoto}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50" />
                            </Border.StrokeShape>
                            <Image Source="{Binding PhotoUrl}" Aspect="AspectFill" />
                        </Border>

                        <!-- Camera badge - Button for reliable tap handling -->
                        <Button
                            Text="&#x1F4F7;"
                            Command="{Binding ChangePhotoCommand}"
                            BackgroundColor="{StaticResource Ink}"
                            TextColor="White"
                            FontSize="14"
                            HeightRequest="34"
                            WidthRequest="34"
                            CornerRadius="17"
                            Padding="0"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            BorderColor="{StaticResource Surface}"
                            BorderWidth="2" />
                </Grid>
            </Grid>

            <VerticalStackLayout Padding="24,20,24,40" Spacing="16" MaximumWidthRequest="600" HorizontalOptions="Center">

                <!-- Name + bio -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label
                        Text="{Binding Username}"
                        FontFamily="JakartaExtraBold"
                        FontSize="26"
                        TextColor="{StaticResource Ink}"
                        HorizontalOptions="Center" />

                    <!-- Display mode -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding IsNotEditing}">
                        <Label
                            Text="{Binding Bio}"
                            FontFamily="JakartaRegular"
                            FontSize="14"
                            TextColor="{StaticResource InkSecondary}"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding HasBio}"
                            MaximumWidthRequest="300" />
                        <Button
                            Text="Edit bio"
                            Command="{Binding StartEditBioCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Brand}"
                            FontFamily="JakartaMedium"
                            FontSize="13"
                            HeightRequest="36"
                            Padding="0" />
                    </VerticalStackLayout>

                    <!-- Edit mode -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsEditing}" MaximumWidthRequest="300">
                        <Border Style="{StaticResource InputFieldBorder}">
                            <Editor
                                Placeholder="Write something about yourself"
                                Text="{Binding DraftBio}"
                                HeightRequest="80"
                                BackgroundColor="Transparent"
                                Margin="4,4,4,4" />
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button
                                Grid.Column="0"
                                Text="Save"
                                Command="{Binding SaveBioCommand}" />
                            <Button
                                Grid.Column="1"
                                Text="Cancel"
                                Command="{Binding CancelEditBioCommand}"
                                Style="{StaticResource OutlineButton}" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Sonder Score card -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource BrandLight}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Label
                                Text="{Binding SonderScore, StringFormat='{0:F1}'}"
                                FontFamily="JakartaExtraBold"
                                FontSize="32"
                                TextColor="{StaticResource Brand}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label
                                Text="Sonder Score"
                                FontFamily="JakartaBold"
                                FontSize="17"
                                TextColor="{StaticResource Ink}" />
                            <Label
                                Text="Your community reputation, earned through hosting and attending plans."
                                FontFamily="JakartaRegular"
                                FontSize="13"
                                TextColor="{StaticResource InkSecondary}"
                                LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Log out -->
                <Button
                    Text="Log Out"
                    Command="{Binding LogOutCommand}"
                    Style="{StaticResource DangerButton}"
                    Margin="0,8,0,0" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
