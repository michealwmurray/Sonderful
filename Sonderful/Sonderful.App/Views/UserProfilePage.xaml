<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sonderful.App.Views.UserProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Sonderful.App.ViewModels"
    x:DataType="vm:UserProfileViewModel"
    Title=""
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid HeightRequest="230">
                <!-- Colored bar -->
                <Border
                    BackgroundColor="{StaticResource Brand}"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    HeightRequest="180"
                    VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,36,36" />
                    </Border.StrokeShape>
                </Border>

                <!-- Back button -->
                <Button
                    Text="←"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="22"
                    Padding="0"
                    WidthRequest="40"
                    HeightRequest="40"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="16,52,0,0" />

                <!-- Avatar -->
                <Grid HorizontalOptions="Center" VerticalOptions="End">
                    <!-- Initials fallback -->
                    <Border
                        HeightRequest="100"
                        WidthRequest="100"
                        BackgroundColor="{StaticResource BrandDark}"
                        Stroke="{StaticResource Surface}"
                        StrokeThickness="4"
                        HorizontalOptions="Center"
                        IsVisible="{Binding HasNoPhoto}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50" />
                        </Border.StrokeShape>
                        <Label
                            Text="{Binding Initials}"
                            FontFamily="JakartaExtraBold"
                            FontSize="38"
                            TextColor="White"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>

                    <!-- Photo -->
                    <Border
                        HeightRequest="100"
                        WidthRequest="100"
                        Stroke="{StaticResource Surface}"
                        StrokeThickness="4"
                        HorizontalOptions="Center"
                        IsVisible="{Binding HasPhoto}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50" />
                        </Border.StrokeShape>
                        <Image Source="{Binding Profile.PhotoUrl}" Aspect="AspectFill" />
                    </Border>
                </Grid>
            </Grid>

            <!-- Loading indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                HorizontalOptions="Center"
                Margin="0,40,0,0" />

            <VerticalStackLayout Padding="24,20,24,40" Spacing="16" MaximumWidthRequest="600" HorizontalOptions="Center">

                <!-- Name + bio -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label
                        Text="{Binding Profile.Username}"
                        FontFamily="JakartaExtraBold"
                        FontSize="26"
                        TextColor="{StaticResource Ink}"
                        HorizontalOptions="Center" />

                    <Label
                        Text="{Binding Profile.Bio}"
                        FontFamily="JakartaRegular"
                        FontSize="14"
                        TextColor="{StaticResource InkSecondary}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding HasBio}"
                        MaximumWidthRequest="300" />
                </VerticalStackLayout>

                <!-- Sonder Score card -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource BrandLight}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            Padding="18,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Label
                                Text="{Binding Profile.SonderScore, StringFormat='{0:F1}'}"
                                FontFamily="JakartaExtraBold"
                                FontSize="32"
                                TextColor="{StaticResource Brand}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label
                                Text="Sonder Score"
                                FontFamily="JakartaBold"
                                FontSize="17"
                                TextColor="{StaticResource Ink}" />
                            <Label
                                Text="Community reputation earned through hosting and attending plans."
                                FontFamily="JakartaRegular"
                                FontSize="13"
                                TextColor="{StaticResource InkSecondary}"
                                LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
