<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Sonderful.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Sonderful.App.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Auth flow (shown first, no tab bar) -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.TabBarIsVisible="False" />

    <!-- Main app tabs -->
    <TabBar>
        <Tab Title="Discover">
            <ShellContent
                Route="DiscoverPage"
                ContentTemplate="{DataTemplate views:DiscoverPage}" />
        </Tab>
        <Tab Title="New Plan">
            <ShellContent
                Route="CreatePlanPage"
                ContentTemplate="{DataTemplate views:CreatePlanPage}" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent
                Route="ProfilePage"
                ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>
